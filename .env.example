# =============================================================================
# Local development Supabase (your own project at supabase.com)
# Copy to .env and fill in from Project Settings → API
# =============================================================================
#
# Supabase dashboard labels → this repo's names:
#   "Project URL"     → SUPABASE_URL / VITE_SUPABASE_URL
#   "anon public"     → SUPABASE_PUBLISHABLE_KEY / VITE_SUPABASE_PUBLISHABLE_KEY
#   "service_role"    → SUPABASE_SERVICE_ROLE_KEY  (server only — never commit)
#   Project ref (subdomain) → SUPABASE_PROJECT_ID / VITE_SUPABASE_PROJECT_ID
#
# Production (Vercel) keeps the original Lovable Supabase — do not change Vercel env.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Optional — needed only for DB migrations via npm run db:push (not stored in app)
# SUPABASE_DB_PASSWORD=your-database-password

# Optional — Stripe, Resend (payments & email in dev)
# STRIPE_SECRET_KEY=
# VITE_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
